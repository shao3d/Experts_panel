#!/usr/bin/env bash
set -euo pipefail

case "${1:-}" in
  search)
    shift
    exec searcharvester-search "$@"
    ;;
  extract)
    shift
    exec searcharvester-extract "$@"
    ;;
  *)
    cat >&2 <<'EOF'
usage:
  searcharvester search --query "..." --max-results 5
  searcharvester extract --url "https://..."

Prefer direct commands in Harvester research tasks:
  searcharvester-search --query "..." --max-results 5
  searcharvester-extract --url "https://..."
EOF
    exit 2
    ;;
esac
