# Hermes agent runtime state — ignore everything under hermes-data/ except
# the SOUL.md persona config we want under version control.
# (Pattern "dir/" excludes the directory itself and nullifies any
#  `!dir/file` negation that follows — use "dir/*" instead.)
hermes-data/*
!hermes-data/SOUL.md
# Researcher tuning: max_tokens + delegation.max_concurrent_children knobs
# that the upstream Hermes template would otherwise overwrite. Versioning
# the whole file so clones get identical behaviour.
!hermes-data/config.yaml
# Harvester delegated-tool routing contract: tiny wrappers and pre_tool_call
# guard are part of the deployable overlay, not runtime state.
!hermes-data/bin/
!hermes-data/bin/searcharvester
!hermes-data/bin/searcharvester-search
!hermes-data/bin/searcharvester-extract
!hermes-data/hooks/
!hermes-data/hooks/research_terminal_guard.py
jobs/
.env.hermes

# Frontend build artifacts
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/package-lock.json
*.tsbuildinfo

# Playwright MCP scratch + debug screenshots
.playwright-mcp/
acp-*.png
